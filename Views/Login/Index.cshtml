@{
    ViewData["Title"] = "Sisteme Giriş";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Ziyaretçi tarafının iskeletini kullanıyoruz
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center align-items-center" style="min-height: 60vh;">
        <div class="col-md-5 col-lg-4">
            <div class="card p-5 border-0 shadow-lg" style="border-radius: 1rem;">
                <h3 class="fw-bold text-center mb-4">Sisteme Giriş</h3>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger text-center fw-bold">@ViewBag.Error</div>
                }

                <form asp-controller="Login" asp-action="Index" method="post">
                    <div class="mb-3">
                        <input type="text" name="username" class="form-control form-control-lg bg-light border-0" placeholder="Kullanıcı: admin" required>
                    </div>
                    <div class="mb-4">
                        <input type="password" name="password" class="form-control form-control-lg bg-light border-0" placeholder="Şifre: 12345" required>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold">Giriş Yap</button>
                </form>
            </div>
        </div>
    </div>
</div>