@model DevBlog.Models.Blog
@{
    ViewBag.Title = "Yazıyı Düzenle - Kontrol Paneli";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <h4 class="fw-bold mb-4">Yazıyı Düzenle</h4>

        <form asp-action="YaziDuzenle" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedDate" />
            <input type="hidden" asp-for="ViewCount" />

            <div class="row mb-3">
                <div class="col-md-8">
                    <label class="form-label fw-semibold">Başlık</label>
                    <input type="text" asp-for="Title" class="form-control bg-light border-0" required>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Kategori</label>
                    <select asp-for="CategoryId" class="form-select bg-light border-0" required>
                        <option value="">Kategori Seçin...</option>
                        @if (ViewBag.Categories != null)
                        {
                            foreach (var cat in ViewBag.Categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Kapak Görseli URL</label>
                <input type="url" asp-for="ImageUrl" class="form-control bg-light border-0" required>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">İçerik</label>
                <input type="hidden" asp-for="Content" id="ContentHidden">

                <div id="editor-container" style="height: 300px; background-color: #fff; border-bottom-left-radius: 0.375rem; border-bottom-right-radius: 0.375rem;">
                    @Html.Raw(Model?.Content)
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center border-top pt-4">
                <div class="form-check form-switch fs-5">
                    <input class="form-check-input" type="checkbox" asp-for="IsPublished">
                    <label class="form-check-label fs-6 ms-2">Herkese Açık Yayınla</label>
                </div>
                <div class="gap-2 d-flex">
                    <a asp-action="Index" class="btn btn-light rounded-pill px-4">İptal</a>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold">Güncelle</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>

    <script>
        var quill = new Quill('#editor-container', {
            theme: 'snow',
            placeholder: 'Harika bir makale yaz...',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, 3, 4, 5, 6, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    ['link', 'blockquote', 'code-block'],
                    ['clean']
                ]
            }
        });

        document.querySelector('form').addEventListener('submit', function() {
            var contentHidden = document.querySelector('#ContentHidden');
            contentHidden.value = quill.root.innerHTML;
        });
    </script>
}