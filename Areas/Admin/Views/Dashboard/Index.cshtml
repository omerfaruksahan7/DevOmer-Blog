@model IEnumerable<DevBlog.Models.Blog>
@{
    ViewBag.Title = "Tüm Yazılar - Kontrol Paneli";
    // Layout yolunun senin projendekiyle eşleştiğinden emin ol
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card border-0 shadow-sm" id="adminListSection">
    <div class="card-body p-0">
        <table class="table table-hover align-middle m-0" style="color: var(--text-color);">
            <thead style="background: rgba(0,0,0,0.02);">
                <tr>
                    <th class="ps-4 border-0">Görsel</th>
                    <th class="border-0">Başlık</th>
                    <th class="border-0">Kategori</th>
                    <th class="border-0">Görüntülenme</th>
                    <th class="border-0">Durum</th>
                    <th class="text-end pe-4 border-0">İşlem</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <img src="@item.ImageUrl" alt="@item.Title" style="width: 50px; height: 50px; object-fit: cover; border-radius: 8px;">
                            </td>
                            <td class="fw-bold">@item.Title</td>
                            <td><span class="badge bg-secondary bg-opacity-25 text-dark">@item.Category?.Name</span></td>
                            <td><i class="fa-regular fa-eye me-2 text-muted"></i>@item.ViewCount</td>
                            <td>
                                @if (item.IsPublished)
                                {
                                    <span class="badge bg-success">Yayında</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Gizli</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="YaziDuzenle" asp-route-id="@item.Id" class="btn btn-sm btn-light text-primary me-2"><i class="fa-solid fa-pen"></i></a>
                                <a asp-action="YaziSil" asp-route-id="@item.Id" class="btn btn-sm btn-light text-danger" onclick="return confirm('Bu yazıyı silmek istediğinize emin misiniz?');"><i class="fa-solid fa-trash"></i></a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="fa-solid fa-folder-open fs-1 mb-3"></i>
                            <p class="mb-0">Henüz hiç blog yazısı eklenmemiş.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        // Layout'taki istatistik kartlarını güncelliyoruz
        document.getElementById('statTotal').innerText = '@(ViewBag.TotalBlogs ?? 0)';
        document.getElementById('statViews').innerText = '@(ViewBag.TotalViews ?? 0)';
    </script>
}