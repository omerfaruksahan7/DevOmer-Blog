
<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg sticky-top py-3">
        <div class="container">
            <a asp-area="" asp-controller="Home" asp-action="Index" class="navbar-brand fw-bold fs-4">
                <i class="fa-solid fa-terminal text-primary me-2"></i>DevOmer
            </a>
            <div class="d-flex align-items-center gap-3">
               @*  <button class="btn btn-sm btn-outline-secondary rounded-circle" id="themeToggle" onclick="toggleTheme()" style="width: 40px; height: 40px;">
                    <i class="fa-solid fa-moon"></i>
                </button> *@
                <a asp-action="Index" id="navAdminBtn" class="btn btn-primary rounded-pill px-4 ">Dashboard</a>
                <a asp-area="" asp-controller="Login" asp-action="Logout"  class="btn btn-danger rounded-pill px-4 ">Çıkış</a>
            </div>
        </div>
    </nav>

    <div id="adminView" >
        <div class="d-flex">
            <aside class="sidebar">
                <div class="text-muted small fw-bold mb-3 px-2">KONTROL PANELİ</div>
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="sidebar-link active" ><i class="fa-solid fa-list me-2"></i>Tüm Yazılar</a>
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="YaziEkle" class="sidebar-link" ><i class="fa-solid fa-pen-nib me-2"></i>Yeni Yazı Ekle</a>
            </aside>

            <main class="flex-grow-1 p-4" style="max-height: calc(100vh - 70px); overflow-y: auto;">

                <div class="row g-4 mb-4">
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm p-4 d-flex flex-row align-items-center gap-3">
                            <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-4 fs-3"><i class="fa-solid fa-file-alt"></i></div>
                            <div><h3 class="fw-bold mb-0" id="statTotal">0</h3><span class="text-muted">Toplam İçerik</span></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm p-4 d-flex flex-row align-items-center gap-3">
                            <div class="bg-success bg-opacity-10 text-success p-3 rounded-4 fs-3"><i class="fa-solid fa-chart-line"></i></div>
                            <div><h3 class="fw-bold mb-0" id="statViews">0</h3><span class="text-muted">Toplam Görüntülenme</span></div>
                        </div>
                    </div>
                </div>                                           
                                
                 <div>
                      @RenderBody()
                </div>

            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
